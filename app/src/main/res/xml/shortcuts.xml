<?xml version="1.0" encoding="utf-8"?>
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">
    <shortcut
        android:enabled="true"
        android:icon="@drawable/calendar"
        android:shortcutId="course_schedule"
        android:shortcutLongLabel="@string/course_schedule"
        android:shortcutShortLabel="@string/course_schedule">
        <intent
            android:action="android.intent.action.VIEW"
            android:targetClass="com.sysu.edu.academic.CourseScheduleActivity"
            android:targetPackage="com.sysu.edu" />
        <categories android:name="android.shortcut.conversation" />
        <capability-binding android:key="actions.intent.CREATE_MESSAGE" />
    </shortcut>
</shortcuts>
