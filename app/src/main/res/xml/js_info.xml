<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.sysu.edu.preference.EditPreference
        app:icon="@drawable/text"
        app:key="title"
        app:persistent="false"
        app:title="@string/title" />

    <com.sysu.edu.preference.EditPreference
        app:icon="@drawable/text"
        app:key="description"
        app:persistent="false"
        app:title="@string/description" />

    <com.sysu.edu.preference.EditPreference
        app:icon="@drawable/account"
        app:key="author"
        app:persistent="false"
        app:title="@string/author" />

    <com.sysu.edu.preference.EditPreference
        app:icon="@drawable/text"
        app:key="matches"
        app:persistent="false"
        app:title="@string/matches" />

    <rikka.preference.SimpleMenuPreference
        app:entries="@array/run"
        app:entryValues="@array/values_2"
        app:icon="@drawable/time"
        app:key="run"
        app:persistent="false"
        app:title="@string/run"
        app:useSimpleSummaryProvider="true" />

    <Preference
        app:allowDividerAbove="true"
        app:icon="@drawable/edit"
        app:key="edit"
        app:persistent="false"
        app:title="@string/edit" />

    <Preference
        app:icon="@drawable/save"
        app:key="save"
        app:persistent="false"
        app:title="@string/save" />

    <Preference
        app:icon="@drawable/warning"
        app:key="state"
        app:persistent="false"
        app:title="@string/disable" />
</androidx.preference.PreferenceScreen>