                android:data="https://github.com/SYSU-Tang/Sysuer/issues"
                android:targetClass="com.sysu.edu.browser.BrowserActivity"
                android:targetPackage="com.sysu.edu" />
        </Preference>
        <Preference
            app:icon="@drawable/money"
            app:key="sponsor"
            app:persistent="false"
            app:summary="@string/sponsor_appreciation"
            app:title="@string/sponsor">
            <intent
                android:data="https://sysu-tang.github.io/sysuer-website/docs/sponsor"
                android:targetClass="com.sysu.edu.browser.BrowserActivity"
                android:targetPackage="com.sysu.edu" />
        </Preference>
    </PreferenceCategory>
    <PreferenceCategory app:title="@string/permission">
        <Preference
            app:defaultValue="true"
            app:icon="@drawable/book"
            app:key="privacyPolicy"
            app:persistent="false"
            app:summary="https://sysu-tang.github.io/sysuer-website/docs/privacyPolicy/"
            app:title="@string/privacy_policy">
            <intent
                android:data="https://sysu-tang.github.io/sysuer-website/docs/privacyPolicy/"
                android:targetClass="com.sysu.edu.browser.BrowserActivity"
                android:targetPackage="com.sysu.edu" />
