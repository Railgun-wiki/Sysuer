<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <PreferenceCategory app:title="@string/version">
        <Preference
            android:key="version"
            app:icon="@drawable/submit"
            app:title="@string/current_version" />
        <Preference
            android:summary="https://github.com/SYSU-Tang/Sysuer/releases"
            app:icon="@drawable/down"
            app:title="@string/download_link">
            <intent
                android:data="https://github.com/SYSU-Tang/Sysuer/releases"
                android:targetClass="com.sysu.edu.browser.BrowserActivity"
                android:targetPackage="com.sysu.edu" />
        </Preference>
        <Preference
            android:summary="https://sysu-tang.github.io/sysuer-website/"
            app:icon="@drawable/web"
            app:title="@string/official_website">
            <intent
                android:data="https://sysu-tang.github.io/sysuer-website/"
                android:targetClass="com.sysu.edu.browser.BrowserActivity"
                android:targetPackage="com.sysu.edu" />
        </Preference>
    </PreferenceCategory>
    <PreferenceCategory app:title="@string/project">
        <Preference
            app:icon="@drawable/account"
            app:summary="https://github.com/SYSU-Tang"
